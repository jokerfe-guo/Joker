# ── Copy this file to apps/web/.env.local for local development ──────────

# Your site's public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Skip Cloudflare Access auth check for /admin in local dev
NEXT_PUBLIC_SKIP_ADMIN_AUTH=true

# Cloudflare Access team domain
# e.g. myteam.cloudflareaccess.com
# Leave empty in local dev — admin will be accessible without JWT
CF_TEAM_DOMAIN=

# ── Giscus comments ───────────────────────────────────────────────────────
# Get these from https://giscus.app after enabling GitHub Discussions
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# ── GitHub Actions secrets (set in repo Settings → Secrets) ──────────────
# CLOUDFLARE_API_TOKEN   — CF API token with Pages + D1 + Workers permissions
# CLOUDFLARE_ACCOUNT_ID  — Your Cloudflare account ID (Dashboard → right sidebar)
